# Logging: DEBUG | INFO | WARNING
# LOG_LEVEL=INFO

# Rate limit (per IP, în memorie): dezactivat în teste / CI cu RATE_LIMIT_ENABLED=false
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GET_PER_MINUTE=240
# RATE_LIMIT_POST_PER_MINUTE=45

# LLM: openai | disabled (răspuns determinist din fragmente RAG, fără apel remote)
LLM_MODE=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Căi date locale
LIBRARY_DIR=./data/library
VECTORSTORE_DIR=./data/vectorstore
PUBLIC_NOTES_DIR=./knowledge/public
# Upload-uri din UI / API (fișiere brute)
UPLOADS_DIR=./data/uploads

# OCR (tab «Cărți & voce»): Tesseract + poppler pe sistem; vezi README
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# OCR_LANG=ron+eng
# OCR_DPI=200

# Arhivare (default: download din Chrome) — unde se scriu fișierele exportate
EXPORTS_DIR=./data/exports

# Obsidian (opțional): cale absolută către vault; dacă e setat, scrie direct acolo
OBSIDIAN_VAULT_PATH=
OBSIDIAN_DEFAULT_SUBDIR=SecondBrain/Inbox

# Notion (integration secret + parent): exact unul dintre PAGE sau DATABASE
# NOTION_TOKEN=secret_...
# NOTION_PARENT_PAGE_ID=   # UUID pagină „Inbox” (fără URL complet)
# NOTION_DATABASE_ID=      # alternativă la parent: UUID bază de date
# NOTION_TITLE_PROPERTY=   # opțional: implicit „Name” pentru DB, „title” pentru pagină copil

# Google Drive — Stage → bibliotecă (OAuth Desktop + token local, vezi README)
# Link opțional către folderul Stage în browser (afișat în UI la fluxul ghidat)
# GOOGLE_DRIVE_STAGE_FOLDER_URL=
# GOOGLE_DRIVE_STAGE_FOLDER_ID=
# GOOGLE_DRIVE_LIBRARY_ROOT_FOLDER_ID=
# GOOGLE_DRIVE_DATA_DIR=./data/drive
# GOOGLE_DRIVE_CLIENT_SECRET_PATH=./data/drive/client_secret.json
# GOOGLE_DRIVE_TOKEN_PATH=./data/drive/token.json
# GOOGLE_DRIVE_MEMORY_PATH=./data/drive/placements.json
# După câte confirmări manuale în istoric trecem la clasificare automată (implicit 2)
# GOOGLE_DRIVE_MIN_AUTO=2
# La propose: subfoldere automate după extensie (.pdf→PDF, .doc/.docx→Documente, imagini→Afise, ppt→Powerpoint, rest→Altele).
# Dezactivare: GOOGLE_DRIVE_THEME_PATHS=false
# Batch (fără pași manuali, mii de fișiere): python scripts/drive_batch_auto_organize.py — vezi README (POST /drive/batch/auto-organize).
